# Frontend
VITE_API_BASE_URL=

# Neon Postgres (serverless functions)
# Vercel'de Production/Preview/Development ortamlarına ekleyin
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
POSTGRES_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
POSTGRES_PRISMA_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Vercel Neon integration kullanıyorsanız (STORAGE_ ile gelenler)
STORAGE_POSTGRES_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
STORAGE_POSTGRES_URL_NO_SSL=postgresql://USER:PASSWORD@HOST/DB
